    "express": "^4.21.2",
    "firebase": "^12.15.0",
    "hls.js": "^1.6.16",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "plyr": "^3.8.4",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "shaka-player": "^5.1.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
